<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="qrscan.db-shm" />
        <exclude domain="database" path="qrscan.db-wal" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="qrscan.db" />
        <include domain="sharedpref" path="qrscan_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
