<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QRScan" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.QRScan.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#004B6F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.QRScan</item>
    </style>
</resources>
